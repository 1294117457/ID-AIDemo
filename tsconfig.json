{
  "compilerOptions": {
    "target": "ES2022",           // 编译目标版本，Node.js 18+ 完美支持 ES2022
    "module": "ESNext",           // 使用现代的 ES Modules (import/export)
    "moduleResolution": "node", 
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": false,
    "declaration": false
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}